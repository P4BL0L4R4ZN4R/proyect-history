{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.1",
        "bpampuch/pdfmake": "^0.2.20",
        "components/jquery": "^3.7",
        "datatables.net/datatables.net-autofill-bs5": "^2.7",
        "datatables.net/datatables.net-bs5": "*",
        "datatables.net/datatables.net-buttons-bs5": "^3.2",
        "datatables.net/datatables.net-datetime": "^1.5",
        "datatables.net/datatables.net-fixedcolumns-bs5": "^5.0",
        "datatables.net/datatables.net-fixedheader-bs5": "^4.0",
        "datatables.net/datatables.net-keytable-bs5": "^2.12",
        "datatables.net/datatables.net-responsive-bs5": "^3.0",
        "datatables.net/datatables.net-rowgroup-bs5": "^1.5",
        "datatables.net/datatables.net-rowreorder-bs5": "^1.5",
        "datatables.net/datatables.net-scroller-bs5": "^2.4",
        "datatables.net/datatables.net-searchbuilder-bs5": "^1.8",
        "datatables.net/datatables.net-searchpanes-bs5": "^2.3",
        "datatables.net/datatables.net-select-bs5": "^3.0",
        "datatables.net/datatables.net-staterestore-bs5": "^1.4",
        "intervention/image": "^3.11",
        "jeroennoten/laravel-adminlte": "^3.15",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1",
        "laravel/ui": "^4.6",
        "maatwebsite/excel": "^3.1",
        "spatie/laravel-permission": "^6.21",
        "stuk/jszip": "^3.0",
        "yajra/laravel-datatables-oracle": "12.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
